[Unit]
Description=Generate runtime configuration files
DefaultDependencies=no
After=local-fs.target systemd-tmpfiles-setup.service
Before=basic.target

# TODO, retry boot? Alternate system version
#OnFailure=emergency.target

[Service]
Type=oneshot
ExecStart=/usr/sbin/nfsense generate-current-config
RemainAfterExit=no

[Install]
WantedBy=basic.target
